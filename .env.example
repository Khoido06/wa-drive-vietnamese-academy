# Database
DATABASE_URL=postgresql://wa_drive:wa_drive_dev@localhost:5432/wa_drive_academy

# ── AI Provider ──────────────────────────────────────────────────────
# Local (free): Ollama
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Production (free LLM): Groq at console.groq.com
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.1-8b-instant
# EMBEDDING_DIMENSIONS=768

# Optional embed-only (small cost, ~$0.00002/query) — better prod RAG
# EMBED_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# EMBED_MODEL=text-embedding-3-small

# PDF source
WA_DRIVER_GUIDE_PDF_PATH=./docs/driver-guide-vi.pdf

# API
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Mutation engine
MUTATION_ENABLED=true
MUTATION_INTERVAL_MS=3600000

# ── Observability (all optional, free tiers) ─────────────────────────
# Sentry — sentry.io (5k errors/mo free)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# PostHog — posthog.com (1M events/mo free)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Upstash — upstash.com (10k commands/day free)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Langfuse — cloud.langfuse.com (50k obs/mo free)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Admin dashboard (set same secret on Vercel + Railway)
# ADMIN_SECRET=your-strong-password

# Clerk auth — clerk.com (optional — sync progress across devices)
# Mức 1: leave unset (mom-only, no login button)
# Mức 2 vercel.app: pk_test_... + sk_test_... (Development — see docs/CLERK.md)
# Mức 3 custom domain: pk_live_... + sk_live_... (Production)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe — dashboard.stripe.com (test mode first)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_FAMILY=price_...
# WEB_URL=https://wa-drive-vietnamese-academy.vercel.app

# Usage limits (free tier defaults)
# FREE_TUTOR_DAILY=10
# FREE_PRACTICE_DAILY=20

# Multi-state RAG (markdown guides in docs/states/)
# DEFAULT_STATE_CODE=WA
# CA_DRIVER_GUIDE_PATH=./docs/states/ca-driver-guide-vi.md
# TX_DRIVER_GUIDE_PATH=./docs/states/tx-driver-guide-vi.md
# FL_DRIVER_GUIDE_PATH=./docs/states/fl-driver-guide-vi.md

# A/B RAG topK test
# RAG_AB_ENABLED=false

# Stream validator — set false for heuristic-only (saves Groq calls)
# STREAM_LLM_VALIDATOR=true
# RAG_CACHE_TTL_SEC=86400
