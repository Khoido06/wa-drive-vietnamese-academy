# Database
DATABASE_URL=postgresql://wa_drive:wa_drive_dev@localhost:5432/wa_drive_academy

# Redis
REDIS_URL=redis://localhost:6379

# ── AI Provider (pick one) ──────────────────────────────────────────
# Local dev: Ollama (free, no API key)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen2.5:7b
# EMBED_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768

# Production (Railway): Groq — free key at console.groq.com
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.1-8b-instant
# EMBEDDING_DIMENSIONS=768
# Import Neon backup for embeddings — Groq has no embed API

# Paid option: OpenAI
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# EMBED_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# PDF source (Vietnamese WA Driver Guide)
WA_DRIVER_GUIDE_PDF_PATH=./docs/driver-guide-vi.pdf

# API
API_PORT=4000
API_URL=http://localhost:4000

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# Mutation engine
MUTATION_ENABLED=true
MUTATION_INTERVAL_MS=3600000
