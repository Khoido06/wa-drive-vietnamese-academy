{
  "name": "wa-drive-vietnamese-academy",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=web --filter=api",
    "dev:all": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter web test:e2e",
    "eval:rag": "pnpm --filter @repo/ai-core eval:rag",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "db:push": "pnpm --filter @repo/db db:push",
    "setup:ollama": "bash scripts/setup-ollama.sh",
    "env:check": "node scripts/connect-all-keys.mjs",
    "env:sync": "node scripts/connect-all-keys.mjs --apply",
    "env:merge-local": "node scripts/connect-all-keys.mjs --merge-local"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
